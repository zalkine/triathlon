# Postgres connection strings.
# DATABASE_URL is the pooled connection used at runtime.
# DATABASE_URL_UNPOOLED is the direct (unpooled) connection used for migrations.
# Neon's Vercel integration sets both automatically. If your provider gives only
# one URL, use it for both.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Long random string used to sign staff login sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Initial admin account created by `prisma db seed`. Change the password!
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me"

# Vercel Blob read/write token, used for admin image uploads on the
# Rules & Trails tab (course maps, photos). Create a Blob store in the Vercel
# dashboard and it is added automatically; locally, copy it here. If unset,
# image upload is disabled and admins paste image URLs manually instead.
BLOB_READ_WRITE_TOKEN=""
