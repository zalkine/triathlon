# Postgres connection strings.
# DATABASE_URL is the pooled connection used at runtime.
# DIRECT_URL is the direct (unpooled) connection used for migrations.
# With Neon/Supabase you get both; if your provider has only one URL, use it for both.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Long random string used to sign staff login sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# Initial admin account created by `prisma db seed`. Change the password!
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me"
